{
  "name": "expo-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node scripts/start-tunnel.js",
    "start:clear": "node scripts/start-tunnel.js -c",
    "start:lan": "node scripts/start-lan.js",
    "start:lan:clear": "node scripts/start-lan.js -c",
    "qr": "node scripts/generate-expo-qr.js",
    "which-ip": "node -e \"console.log(require('./scripts/resolve-lan-ip').resolveLanIp())\"",
    "android": "expo start --android --lan",
    "ios": "expo start --ios --lan",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-webview": "13.15.0"
  },
  "private": true,
  "devDependencies": {
    "qrcode": "^1.5.4"
  }
}
